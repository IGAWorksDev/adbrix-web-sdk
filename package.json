{
  "name": "@igaworks/adbrix-web-sdk",
  "version": "3.2.0-beta.0",
  "description": "Adbrix Web SDK",
  "main": "./dist/npm/index.cjs",
  "types": "./types/index.d.ts",
  "unpkg": "./dist/abx2-web-sdk.min.js",
  "jsdelivr": "./dist/abx2-web-sdk.min.js",
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.mts",
        "default": "./dist/npm/index.mjs"
      },
      "require": {
        "types": "./types/index.d.ts",
        "default": "./dist/npm/index.cjs"
      },
      "types": "./types/index.d.ts",
      "default": "./dist/npm/index.cjs"
    },
    "./browser": "./dist/abx2-web-sdk.min.js",
    "./package.json": "./package.json"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/npm/**/*",
    "dist/abx2-web-sdk.min.js",
    "dist/abx2-web-sdk.min.js.LICENSE.txt",
    "types/**/*"
  ],
  "sideEffects": true,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IGAWorksDev/adbrix-web-sdk.git"
  },
  "engines": {
    "node": ">= 8.0.0",
    "npm": ">= 5.0.0"
  },
  "keywords": [
    "adbrix",
    "web-sdk",
    "analytics",
    "attribution"
  ],
  "author": "igaworks",
  "license": "SEE LICENSE IN LICENSE"
}
